{
  "compilerOptions": {
    // File Layout
    "rootDir": "src",
    "outDir": "dist",
    // Environment Settings
    "module": "esnext",
    "moduleResolution": "Node",
    "target": "es2022",
    "lib": [
      "es2022",
      "dom"
    ],
    "types": [
      "node"
    ],
    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    // Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  }
}